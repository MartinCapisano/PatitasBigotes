# ============================================================
# CONFIGURACION BASE COMPARTIDA DEL PROYECTO
# Estas variables pueden mantenerse iguales en cualquier equipo
# de desarrollo local salvo que se decida otra convencion.
# ============================================================

DATABASE_URL=
# local o demo = permite correr seed_demo (datos/admin de prueba).
# staging o production = seed_demo se niega a correr para evitar tocar datos reales.
APP_ENV=local
JWT_SECRET=REEMPLAZAR_CON_UN_SECRET_LARGO
JWT_ALGORITHM=HS256
JWT_ISSUER=patitasbigotes-api
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30
APP_BASE_URL=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AUTH_COOKIE_ACCESS_NAME=pb_at
AUTH_COOKIE_REFRESH_NAME=pb_rt
AUTH_COOKIE_SAMESITE=lax
# Vacio = se infiere de APP_BASE_URL (true si es https). Poner true/false solo para forzar el valor.
AUTH_COOKIE_SECURE=
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH_ACCESS=/
AUTH_COOKIE_PATH_REFRESH=/auth

# ============================================================
# VARIABLES DEPENDIENTES DEL ENTORNO O DE CREDENCIALES
# Completar solo si se van a usar esas integraciones.
# ============================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=

# ============================================================
# TRANSFERENCIA BANCARIA
# Unico metodo de pago online. OBLIGATORIAS: el backend no
# arranca si falta alguna, porque sin esto no se puede cobrar.
# Los valores de abajo son de mentira, sirven para desarrollo.
# ============================================================

BANK_TRANSFER_ALIAS=alias.de.prueba
BANK_TRANSFER_CBU=0000000000000000000000
BANK_TRANSFER_BANK_NAME=Banco de Prueba
BANK_TRANSFER_HOLDER=Titular De Prueba
BANK_TRANSFER_CUIT=20-12345678-9

# WhatsApp donde el cliente manda el comprobante. Se acepta
# como lo escribe una persona (+54 9 351 123-4567); el backend
# se queda solo con los digitos para armar el enlace wa.me.
WHATSAPP_NUMBER=5493511234567

# ============================================================
# MERCADO PAGO
# Completar solo si se quiere probar la integracion real.
# ============================================================

# Candado de la pausa de MercadoPago. En false (o ausente) el backend
# RECHAZA iniciar cualquier pago con method=mercadopago, aunque se lo
# pida por API a mano. Poner en true para trabajar sobre la integracion.
# El frontend tiene su propio VITE_MERCADOPAGO_ENABLED: son dos cosas
# distintas y ambas tienen que estar en true para ver MP funcionando.
MERCADOPAGO_ENABLED=false

MERCADOPAGO_ACCESS_TOKEN=REEMPLAZAR_CON_ACCESS_TOKEN_DE_PRUEBA
MERCADOPAGO_TIMEOUT_SECONDS=10
MERCADOPAGO_SUCCESS_URL=http://localhost:5173/payments/success
MERCADOPAGO_FAILURE_URL=http://localhost:5173/payments/failure
MERCADOPAGO_PENDING_URL=http://localhost:5173/payments/pending
MERCADOPAGO_NOTIFICATION_URL=http://localhost:8000/payments/webhook/mercadopago
MERCADOPAGO_WEBHOOK_SECRET=REEMPLAZAR_CON_WEBHOOK_SECRET_DE_PRUEBA
MERCADOPAGO_WEBHOOK_MAX_AGE_SECONDS=300

# ============================================================
# VARIABLE QUE MARCA SI MP ES REAL O NO
# sandbox = pruebas
# production = real
# ============================================================

MERCADOPAGO_ENV=sandbox

# ============================================================
# PARAMETROS OPERATIVOS COMPARTIDOS
# Solo hace falta cambiarlos si se desea otra configuracion.
# ============================================================

WEBHOOK_REPROCESS_INTERVAL_MINUTES=30
WEBHOOK_REPROCESS_BATCH_SIZE=25
WEBHOOK_REPROCESS_MAX_ATTEMPTS=4
WEBHOOK_REPROCESS_BASE_DELAY_MINUTES=30
WEBHOOK_REPROCESS_MAX_DELAY_MINUTES=720

PAYMENTS_RECONCILE_INTERVAL_MINUTES=180
PAYMENTS_RECONCILE_BATCH_SIZE=50
PAYMENTS_RECONCILE_MAX_AGE_HOURS=24
PAYMENTS_RECONCILE_MIN_AGE_MINUTES=15

AUTH_ACTION_TOKENS_PRUNE_INTERVAL_MINUTES=1440
AUTH_ACTION_TOKENS_PRUNE_OLDER_THAN_DAYS=7
AUTH_ACTION_TOKENS_PRUNE_BATCH_SIZE=500

AUTH_LOGIN_THROTTLES_PRUNE_INTERVAL_MINUTES=1440
AUTH_LOGIN_THROTTLES_PRUNE_OLDER_THAN_DAYS=14
AUTH_LOGIN_THROTTLES_PRUNE_BATCH_SIZE=1000

STOCK_RESERVATIONS_JOB_INTERVAL_MINUTES=60
STOCK_RESERVATIONS_JOB_BATCH_LIMIT=200
STOCK_RESERVATIONS_JOB_MAX_BATCHES=20
