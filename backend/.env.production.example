# ============================================================
# PLANTILLA DE VARIABLES DE PRODUCCION (backend en Render)
# ------------------------------------------------------------
# Estos valores NO van en el repo. Se cargan en el dashboard de
# Render (Environment) del web service. Este archivo es solo la
# lista de referencia de que hay que setear y con que forma.
#
# Arquitectura de produccion:
#   - Frontend: build estatico de Vite en Vercel / Cloudflare Pages
#   - Backend:  este servicio FastAPI en Render (free tier)
#   - DB:       Postgres gestionada en Supabase (proyecto aparte)
# ============================================================

# Marca el entorno. Habilita validaciones de produccion y
# deshabilita el seed demo (ver source/seed_demo.py).
APP_ENV=production

# --- Base de datos (Supabase) ------------------------------
# Connection string del proyecto de Supabase (Project Settings ->
# Database -> Connection string -> URI). Usar el pooler si esta
# disponible. Incluye sslmode=require.
DATABASE_URL=postgresql://postgres:<password>@<host>.supabase.co:5432/postgres?sslmode=require

# --- JWT ----------------------------------------------------
JWT_SECRET=<secret-largo-y-aleatorio>
JWT_ALGORITHM=HS256
JWT_ISSUER=patitasbigotes-api
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- URLs publicas ------------------------------------------
# APP_BASE_URL = URL publica del FRONTEND (Vercel/Cloudflare).
# Se usa para armar los links de verificacion/reset de email.
APP_BASE_URL=https://<tu-frontend>.vercel.app

# --- Cross-origin real (frontend y backend en dominios distintos) ---
# Allowlist EXACTA de origenes del frontend, separados por coma.
# Sin wildcards. Debe coincidir con el dominio real del frontend.
CORS_ALLOW_ORIGINS=https://<tu-frontend>.vercel.app

# Cookies cross-site: SameSite=None + Secure=true son obligatorios
# para que el navegador acepte la cookie entre dominios distintos.
# La proteccion CSRF real la da el middleware de Origin/Referer
# (source/dependencies/csrf_d.py), no SameSite, asi que esto no
# debilita la seguridad.
AUTH_COOKIE_ACCESS_NAME=pb_at
AUTH_COOKIE_REFRESH_NAME=pb_rt
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_SECURE=true
# Vacio = cookie host-only del dominio del backend (Render). No se
# comparte dominio con el frontend; el frontend la envia via
# withCredentials + CORS con credenciales.
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH_ACCESS=/
AUTH_COOKIE_PATH_REFRESH=/auth

# --- Transferencia bancaria (OBLIGATORIO) -------------------
# Es el unico metodo de pago online del lanzamiento: sin estos
# valores el backend NO ARRANCA. Tienen que ser los datos REALES
# de la cuenta del comercio -- el cliente los lee y le transfiere
# plata a esa cuenta. Ver docs/banktransfer.md.
BANK_TRANSFER_ALIAS=<alias-real-de-la-cuenta>
BANK_TRANSFER_CBU=<cbu-real-de-la-cuenta>
BANK_TRANSFER_BANK_NAME=<nombre-del-banco>
BANK_TRANSFER_HOLDER=<nombre-del-titular>
BANK_TRANSFER_CUIT=<cuit-o-cuil-del-titular>

# WhatsApp REAL donde el cliente manda el comprobante. Se acepta
# como lo escribe una persona (+54 9 351 123-4567); el backend se
# queda solo con los digitos para armar el enlace wa.me.
WHATSAPP_NUMBER=<whatsapp-del-comercio>

# --- Mercado Pago (EN PAUSA) --------------------------------
# MercadoPago esta pausado: el unico metodo de pago online del
# lanzamiento es la transferencia bancaria. Ver docs/mercadopago.md.
#
# MERCADOPAGO_ENABLED=false es el candado: el backend rechaza iniciar
# pagos con method=mercadopago. Mientras siga en false, NADA de lo que
# esta abajo hace falta y se puede dejar con los placeholders.
# Para reactivar MP: poner esto en true, completar lo de abajo con
# valores reales y poner VITE_MERCADOPAGO_ENABLED=true en el frontend.
MERCADOPAGO_ENABLED=false

# Apuntar a las URLs REALES de produccion, no a localhost.
# success/failure/pending = pantallas del FRONTEND.
# notification = endpoint del BACKEND que recibe el webhook.
MERCADOPAGO_ACCESS_TOKEN=<access-token-de-produccion>
MERCADOPAGO_ENV=production
MERCADOPAGO_TIMEOUT_SECONDS=10
MERCADOPAGO_SUCCESS_URL=https://<tu-frontend>.vercel.app/payments/success
MERCADOPAGO_FAILURE_URL=https://<tu-frontend>.vercel.app/payments/failure
MERCADOPAGO_PENDING_URL=https://<tu-frontend>.vercel.app/payments/pending
MERCADOPAGO_NOTIFICATION_URL=https://<tu-backend>.onrender.com/payments/webhook/mercadopago
MERCADOPAGO_WEBHOOK_SECRET=<webhook-secret-de-produccion>
MERCADOPAGO_WEBHOOK_MAX_AGE_SECONDS=300

# --- SMTP (OBLIGATORIO en produccion) -----------------------
# Sin esto no sale la verificacion de email, ni el reset de
# contrasena, ni los avisos de una orden. El backend NO ARRANCA
# si falta SMTP_HOST, SMTP_USERNAME, SMTP_PASSWORD o MAIL_FROM.
#
# Los envios se hacen despues del commit y se tragan sus errores
# (una venta no se cae porque Gmail este caido), asi que en runtime
# una credencial revocada no da ningun sintoma: la tienda anda y
# nadie recibe nada. El boot es el unico lugar donde eso se ve.
#
# Trampas de Gmail:
#  1. SMTP_PASSWORD es un "app password" de Google, no la clave de
#     la cuenta. Requiere verificacion en 2 pasos activada, sino
#     Google ni siquiera ofrece la opcion.
#  2. MAIL_FROM tiene que ser la MISMA direccion que SMTP_USERNAME.
#     Si no, Gmail reescribe el header From y el cliente ve la
#     casilla real igual.
#  3. Un mail desde @gmail.com hablando de ordenes cae en spam mas
#     seguido que uno de dominio propio.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=patitasbigotes@gmail.com
SMTP_PASSWORD=<app-password-de-google>
SMTP_USE_TLS=true
MAIL_FROM=patitasbigotes@gmail.com

# --- Mantenimiento por ping externo -------------------------
# Secreto que autoriza el endpoint /internal/maintenance/run,
# disparado por el cron de GitHub Actions. Generar uno aleatorio
# y cargar el MISMO valor como secret del workflow.
MAINTENANCE_RUN_TOKEN=<token-largo-y-aleatorio>

# Parametros operativos de los jobs (mismos defaults que en local;
# ajustar si hace falta). Ver backend/.env.example para la lista
# completa de WEBHOOK_REPROCESS_*, PAYMENTS_RECONCILE_*, etc.
