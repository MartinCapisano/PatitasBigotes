# Python cache
__pycache__/
*.py[cod]
.pytest_cache/

# Generated runtime and local temp artifacts
*.db-journal

# Local environment files (never commit secrets)
.env
.env.*
!.env.example
!.env.*.example
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.*.example

# Frontend
frontend/node_modules/
frontend/dist/
# NOTE: src/types/api.generated.ts is committed (not ignored) so the frontend
# builds hermetically on Vercel/Cloudflare, which have no Python to regenerate
# it from the backend. CI regenerates it and fails on drift (see ci.yml).
frontend/tmp/logs/*
frontend/tmp/tsbuildinfo/*
frontend/*.tsbuildinfo
!frontend/tmp/logs/.gitkeep
!frontend/tmp/tsbuildinfo/.gitkeep

# Backend: generated OpenAPI schema (regenerated via backend/scripts/export_openapi.py)
backend/openapi.json

# Backend tmp convention
backend/tmp/logs/*
backend/tmp/tests/*
backend/tmp/migrations/*
!backend/tmp/logs/.gitkeep
!backend/tmp/tests/.gitkeep
!backend/tmp/migrations/.gitkeep
