# ============================================================
# PLANTILLA DE VARIABLES DE PRODUCCION (frontend)
# ------------------------------------------------------------
# OJO: Vite "hornea" estas variables dentro del build (no se leen
# en runtime). Se cargan como Environment Variables en el dashboard
# de Vercel / Cloudflare Pages ANTES de correr `npm run build`.
# No commitear un .env.production con valores reales.
# ============================================================

# URL publica del BACKEND en Render. El frontend le pega aca.
VITE_API_BASE_URL=https://<tu-backend>.onrender.com

# Timeout de las requests HTTP en milisegundos. El free tier de
# Render "duerme" tras 15 min sin trafico y tarda 30-60s en
# responder la primera request al despertar, por eso el default de
# produccion es alto (60s). Ver frontend/src/services/http.ts.
VITE_API_TIMEOUT_MS=60000
