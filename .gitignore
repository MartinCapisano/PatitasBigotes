# Python cache
__pycache__/
*.py[cod]
.pytest_cache/

# Generated runtime and local temp artifacts
*.db-journal

# Local environment files (never commit secrets)
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# Frontend
frontend/node_modules/
frontend/dist/
frontend/tmp/logs/*
frontend/tmp/tsbuildinfo/*
frontend/*.tsbuildinfo
!frontend/tmp/logs/.gitkeep
!frontend/tmp/tsbuildinfo/.gitkeep

# Backend tmp convention
backend/tmp/logs/*
backend/tmp/tests/*
backend/tmp/migrations/*
!backend/tmp/logs/.gitkeep
!backend/tmp/tests/.gitkeep
!backend/tmp/migrations/.gitkeep
